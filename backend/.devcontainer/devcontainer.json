{
  "name": "Versus - Backend (Spring Boot)",

  "dockerComposeFile": [
    "../../docker-compose.yml",
    "../../docker-compose.dev.yml"
  ],

  "service": "backend",
  "workspaceFolder": "/app",

  "customizations": {
    "vscode": {
      "extensions": [
        // Java (pack oficial de Microsoft — incluye Language Support, Debugger, Test Runner, Maven, Project Manager)
        "vscjava.vscode-java-pack",
        // Spring Boot
        "vmware.vscode-spring-boot",
        "vscjava.vscode-spring-initializr",
        "vscjava.vscode-spring-boot-dashboard",
        // Lombok (necesario para que el IDE no marque errores en clases con @Data, etc.)
        "GabrielBB.vscode-lombok",
        // Formato y utilidades
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "postman.postman-for-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        // Que Java use el JDK del contenedor y no busque uno local
        "java.jdt.ls.java.home": "/opt/java/openjdk",
        // Lombok: symlink creado en postCreateCommand apunta al jar real
        // -Xmx limita el heap de JDT LS para que no mate el contenedor al indexar
        "java.jdt.ls.vmargs": "-javaagent:/opt/lombok/lombok.jar -Xms256m -Xmx1536m -XX:+UseG1GC",
        "workbench.colorCustomizations": {
          "titleBar.activeBackground": "#1a3a1a",
          "titleBar.activeForeground": "#FFFFFF",
          "titleBar.inactiveBackground": "#0d1f0d99",
          "titleBar.inactiveForeground": "#FFFFFFCC"
        }
      }
    }
  },

  // Pre-descarga dependencias y crea symlink de Lombok en ruta fija para JDT LS
  "postCreateCommand": "[ -f pom.xml ] && mvn dependency:go-offline -B || true && mkdir -p /opt/lombok && ln -sf $(find /root/.m2/repository/org/projectlombok/lombok -name 'lombok-*.jar' ! -name '*sources*' | sort -V | tail -1) /opt/lombok/lombok.jar",

  "forwardPorts": [
    8080, // API
    5005, // Debug remoto
    5432, // PostgreSQL
    5050  // pgAdmin
  ],

  "remoteUser": "root"
}
